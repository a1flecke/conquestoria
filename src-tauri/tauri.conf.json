{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Conquestoria",
  "version": "0.1.0",
  "identifier": "com.conquestoria.desktop",
  "build": {
    "beforeDevCommand": {
      "cwd": "../",
      "script": "yarn dev --host 127.0.0.1",
      "wait": false
    },
    "beforeBuildCommand": {
      "cwd": "../",
      "script": "yarn build:tauri",
      "wait": true
    },
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Conquestoria",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 220
        }
      }
    }
  }
}
